.container {
  min-height: 100vh;
  background-color: #FFF8F0;
  padding: 40rpx 24rpx;
  box-sizing: border-box;
}

.record-header {
  text-align: center;
  margin-bottom: 60rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #4A3424;
  margin-bottom: 12rpx;
}

.header-hint {
  font-size: 26rpx;
  color: #8B7355;
}

.record-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
}

.record-button {
  width: 240rpx;
  height: 240rpx;
  background: linear-gradient(135deg, #FF9A6B 0%, #FFB088 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 32rpx rgba(255, 154, 107, 0.4);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.record-button::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: radial-gradient(circle at 30% 30%, rgba(255, 255, 255, 0.3), transparent);
  border-radius: 50%;
}

.record-button.pressed {
  transform: scale(0.95);
  box-shadow: 0 6rpx 16rpx rgba(255, 154, 107, 0.5);
}

.record-button.recording {
  animation: pulse 1.5s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% {
    box-shadow: 0 12rpx 32rpx rgba(255, 154, 107, 0.4);
  }
  50% {
    box-shadow: 0 20rpx 48rpx rgba(255, 154, 107, 0.6);
  }
}

.paw-container {
  width: 160rpx;
  height: 160rpx;
  position: relative;
}

.paw {
  position: relative;
  width: 100%;
  height: 100%;
}

.pad {
  position: absolute;
  background: #FFFFFF;
  border-radius: 50%;
}

.pad-1 {
  top: 10rpx;
  left: 30rpx;
  width: 40rpx;
  height: 40rpx;
}

.pad-2 {
  top: 10rpx;
  right: 30rpx;
  width: 40rpx;
  height: 40rpx;
}

.pad-3 {
  bottom: 10rpx;
  left: 10rpx;
  width: 35rpx;
  height: 35rpx;
}

.pad-4 {
  bottom: 10rpx;
  right: 10rpx;
  width: 35rpx;
  height: 35rpx;
}

.pad-5 {
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 60rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.8);
}

.record-duration {
  margin-top: 32rpx;
}

.duration-text {
  font-size: 48rpx;
  font-weight: 600;
  color: #FF9A6B;
  font-family: 'Courier New', monospace;
}

.record-wave {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin-top: 32rpx;
  height: 80rpx;
}

.wave-bar {
  width: 8rpx;
  background: linear-gradient(to top, #FF9A6B, #FFB088);
  border-radius: 4rpx;
  animation: wave 0.8s ease-in-out infinite;
}

@keyframes wave {
  0%, 100% {
    transform: scaleY(0.3);
  }
  50% {
    transform: scaleY(1);
  }
}

.sound-list-section {
  margin-top: 40rpx;
}

.section-title {
  display: flex;
  align-items: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #4A3424;
  margin-bottom: 24rpx;
}

.title-icon {
  margin-right: 12rpx;
}

.sound-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.sound-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 154, 107, 0.1);
}

.sound-player {
  width: 64rpx;
  height: 64rpx;
  background: linear-gradient(135deg, #FF9A6B 0%, #FFB088 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.sound-player.playing .wave {
  animation: wave 0.5s ease-in-out infinite;
}

.speaker {
  position: relative;
  width: 32rpx;
  height: 32rpx;
}

.wave {
  position: absolute;
  bottom: 0;
  width: 5rpx;
  height: 12rpx;
  background: #FFFFFF;
  border-radius: 3rpx;
}

.wave-1 {
  left: 0;
}

.wave-2 {
  left: 13rpx;
  animation-delay: 0.15s;
}

.wave-3 {
  left: 27rpx;
  animation-delay: 0.3s;
}

.sound-info {
  flex: 1;
}

.sound-desc {
  display: block;
  font-size: 28rpx;
  color: #4A3424;
}

.sound-duration {
  display: block;
  font-size: 22rpx;
  color: #C49B7D;
  margin-top: 4rpx;
}

.sound-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FFF8F0;
  border-radius: 50%;
  font-size: 24rpx;
}

.button-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 24rpx;
  padding: 24rpx;
  background: #FFFFFF;
  box-shadow: 0 -4rpx 20rpx rgba(255, 154, 107, 0.1);
}

.btn-cancel, .btn-confirm {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  border: none;
}

.btn-cancel {
  background: #FFF8F0;
  color: #8B7355;
  border: 2rpx solid #F5E6D3;
}

.btn-confirm {
  background: linear-gradient(135deg, #FF9A6B 0%, #FFB088 100%);
  color: #FFFFFF;
}

.btn-confirm.disabled {
  opacity: 0.5;
}

.permission-tip {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: #FFFFFF;
  padding: 40rpx;
  border-radius: 20rpx;
  text-align: center;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
}

.permission-tip text {
  display: block;
  font-size: 28rpx;
  color: #4A3424;
  margin-bottom: 24rpx;
}

.go-settings {
  background: linear-gradient(135deg, #FF9A6B 0%, #FFB088 100%);
  color: #FFFFFF;
  border: none;
  border-radius: 24rpx;
  padding: 16rpx 48rpx;
  font-size: 28rpx;
}