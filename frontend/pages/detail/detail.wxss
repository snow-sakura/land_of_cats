.container {
  min-height: 100vh;
  background-color: #FFF8F0;
  padding-bottom: 160rpx;
}

.photo-carousel {
  position: relative;
  width: 100%;
  height: 480rpx;
  background: #4A3424;
  border-radius: 0 0 32rpx 32rpx;
  overflow: hidden;
}

.swiper {
  width: 100%;
  height: 100%;
}

.carousel-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.carousel-count {
  position: absolute;
  bottom: 20rpx;
  right: 24rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #FFFFFF;
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
}

.info-card {
  margin: -40rpx 24rpx 24rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 154, 107, 0.2);
  position: relative;
  z-index: 10;
}

.info-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.cat-name {
  font-size: 40rpx;
  font-weight: 600;
  color: #4A3424;
  font-family: 'ZCOOL KuaiLe', cursive;
}

.cat-badge {
  font-size: 24rpx;
  color: #FF9A6B;
  background: rgba(255, 154, 107, 0.15);
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
}

.location-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.location-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.location-text {
  font-size: 26rpx;
  color: #8B7355;
}

.tags-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  padding: 10rpx 20rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
}

.tag-primary {
  background: rgba(255, 154, 107, 0.15);
  color: #FF9A6B;
}

.tag-success {
  background: rgba(163, 212, 174, 0.2);
  color: #5B8C6A;
}

.tag-info {
  background: rgba(196, 155, 125, 0.15);
  color: #C49B7D;
}

.section-card {
  margin: 0 24rpx 24rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 154, 107, 0.1);
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #F5E6D3;
}

.section-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #4A3424;
}

.detail-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.detail-item {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.detail-label {
  font-size: 26rpx;
  color: #8B7355;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.detail-value {
  font-size: 26rpx;
  color: #4A3424;
  flex: 1;
  text-align: right;
}

.health-badge {
  font-size: 26rpx;
  padding: 8rpx 20rpx;
  border-radius: 16rpx;
  background: rgba(163, 212, 174, 0.2);
  color: #5B8C6A;
}

.sound-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.sound-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #FFF8F0;
  border-radius: 16rpx;
}

.sound-player {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #FF9A6B 0%, #FFB088 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.sound-player.playing .wave {
  animation: wave 0.5s ease-in-out infinite;
}

.speaker {
  position: relative;
  width: 40rpx;
  height: 40rpx;
}

.wave {
  position: absolute;
  bottom: 0;
  width: 6rpx;
  height: 16rpx;
  background: #FFFFFF;
  border-radius: 3rpx;
}

.wave-1 {
  left: 0;
  animation-delay: 0s;
}

.wave-2 {
  left: 17rpx;
  animation-delay: 0.15s;
}

.wave-3 {
  left: 34rpx;
  animation-delay: 0.3s;
}

@keyframes wave {
  0%, 100% { height: 16rpx; }
  50% { height: 32rpx; }
}

.sound-info {
  flex: 1;
}

.sound-desc {
  display: block;
  font-size: 28rpx;
  color: #4A3424;
}

.sound-duration {
  display: block;
  font-size: 22rpx;
  color: #C49B7D;
  margin-top: 4rpx;
}

.map-area {
  position: relative;
  border-radius: 16rpx;
  overflow: hidden;
}

.mini-map {
  width: 100%;
  height: 240rpx;
}

.map-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(0, 0, 0, 0.6);
  padding: 16rpx 20rpx;
}

.map-name {
  display: block;
  font-size: 26rpx;
  color: #FFFFFF;
}

.map-address {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 4rpx;
}

/* 文本地址卡片（无地图时） */
.loc-text-body {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}
.loc-text-name {
  font-size: 28rpx;
  color: #4A3424;
  font-weight: 500;
}
.loc-text-address {
  font-size: 24rpx;
  color: #8B7355;
}

.notes-content {
  font-size: 28rpx;
  color: #4A3424;
  line-height: 1.6;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 24rpx;
  padding: 24rpx;
  background: #FFFFFF;
  box-shadow: 0 -4rpx 20rpx rgba(255, 154, 107, 0.15);
}

.btn-edit, .btn-delete {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 44rpx;
  font-size: 28rpx;
  border: none;
}

.btn-edit {
  background: linear-gradient(135deg, #FF9A6B 0%, #FFB088 100%);
  color: #FFFFFF;
}

.btn-delete {
  background: #FFF8F0;
  color: #FF7B7B;
  border: 2rpx solid #FF7B7B;
}

.btn-icon {
  margin-right: 8rpx;
  font-size: 28rpx;
}