page {
  background-color: #FFF8F0;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', 'Helvetica Neue', Helvetica, Arial, sans-serif;
  color: #4A3424;
}

:root {
  --primary-color: #FF9A6B;
  --primary-light: #FFB088;
  --bg-color: #FFF8F0;
  --bg-card: #FFFFFF;
  --text-color: #4A3424;
  --text-light: #8B7355;
  --border-color: #C49B7D;
  --success-color: #A3D4AE;
  --warning-color: #FF7B7B;
  --card-radius: 20rpx;
  --btn-radius: 24rpx;
  --tag-radius: 16rpx;
}

.container {
  padding: 20rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 154, 107, 0.15);
}

.btn-primary {
  background: linear-gradient(135deg, #FF9A6B 0%, #FFB088 100%);
  color: #FFFFFF;
  border: none;
  border-radius: 24rpx;
  padding: 24rpx 48rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.btn-secondary {
  background: #FFF8F0;
  color: #FF9A6B;
  border: 2rpx solid #FF9A6B;
  border-radius: 24rpx;
  padding: 24rpx 48rpx;
  font-size: 28rpx;
}

.tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  margin-right: 12rpx;
  margin-bottom: 12rpx;
}

.tag-primary {
  background: rgba(255, 154, 107, 0.15);
  color: #FF9A6B;
}

.tag-success {
  background: rgba(163, 212, 174, 0.2);
  color: #5B8C6A;
}

.tag-warning {
  background: rgba(255, 123, 123, 0.15);
  color: #FF7B7B;
}

.tag-info {
  background: rgba(196, 155, 125, 0.15);
  color: #C49B7D;
}

.text-primary {
  color: #FF9A6B;
}

.text-success {
  color: #A3D4AE;
}

.text-warning {
  color: #FF7B7B;
}

.text-light {
  color: #8B7355;
}

.flex {
  display: flex;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.gap-sm {
  gap: 12rpx;
}

.gap-md {
  gap: 20rpx;
}

.gap-lg {
  gap: 32rpx;
}

.mt-sm {
  margin-top: 16rpx;
}

.mt-md {
  margin-top: 24rpx;
}

.mt-lg {
  margin-top: 32rpx;
}

.mb-sm {
  margin-bottom: 16rpx;
}

.mb-md {
  margin-bottom: 24rpx;
}

.mb-lg {
  margin-bottom: 32rpx;
}