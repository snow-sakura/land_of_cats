<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title || '管理后台' %> — 流浪猫足迹</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: #FFF8F0;
      color: #4A3728;
      min-height: 100vh;
    }

    /* 导航栏 */
    .navbar {
      background: linear-gradient(135deg, #FF9A6B, #FFB088);
      padding: 0 24px;
      height: 56px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      box-shadow: 0 2px 8px rgba(255, 154, 107, 0.3);
    }
    .navbar-brand {
      color: #fff;
      font-size: 18px;
      font-weight: 600;
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .navbar-nav {
      display: flex;
      gap: 4px;
      align-items: center;
    }
    .navbar-nav a {
      color: rgba(255,255,255,0.9);
      text-decoration: none;
      padding: 8px 16px;
      border-radius: 8px;
      font-size: 14px;
      transition: background 0.2s;
    }
    .navbar-nav a:hover,
    .navbar-nav a.active {
      background: rgba(255,255,255,0.2);
      color: #fff;
    }
    .navbar-user {
      color: rgba(255,255,255,0.8);
      font-size: 13px;
      margin-right: 12px;
    }

    /* 主容器 */
    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 24px;
    }

    /* 页面标题 */
    .page-header {
      margin-bottom: 24px;
    }
    .page-title {
      font-size: 22px;
      font-weight: 600;
      color: #4A3728;
    }
    .page-subtitle {
      font-size: 14px;
      color: #999;
      margin-top: 4px;
    }

    /* 卡片 */
    .card {
      background: #fff;
      border-radius: 12px;
      padding: 20px;
      margin-bottom: 16px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    }
    .card-title {
      font-size: 15px;
      font-weight: 600;
      color: #4A3728;
      margin-bottom: 16px;
      padding-bottom: 12px;
      border-bottom: 1px solid #f0ebe5;
    }

    /* 统计卡片 */
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 16px;
      margin-bottom: 24px;
    }
    .stat-card {
      background: #fff;
      border-radius: 12px;
      padding: 20px;
      text-align: center;
      box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    }
    .stat-number {
      font-size: 32px;
      font-weight: 700;
      color: #FF9A6B;
    }
    .stat-label {
      font-size: 13px;
      color: #999;
      margin-top: 4px;
    }

    /* 表格 */
    .table-wrap {
      overflow-x: auto;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 14px;
    }
    th, td {
      text-align: left;
      padding: 12px 8px;
      border-bottom: 1px solid #f0ebe5;
    }
    th {
      font-weight: 600;
      color: #666;
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    tr:hover td {
      background: #FFF8F0;
    }

    /* 标签 */
    .tag {
      display: inline-block;
      background: #FFF0E6;
      color: #FF9A6B;
      padding: 2px 10px;
      border-radius: 12px;
      font-size: 12px;
      margin: 2px 4px 2px 0;
    }

    /* 按钮 */
    .btn {
      display: inline-block;
      padding: 8px 20px;
      border-radius: 8px;
      font-size: 14px;
      font-weight: 500;
      text-decoration: none;
      cursor: pointer;
      border: none;
      transition: all 0.2s;
    }
    .btn-primary {
      background: #FF9A6B;
      color: #fff;
    }
    .btn-primary:hover { background: #e8895d; }
    .btn-sm {
      padding: 4px 12px;
      font-size: 12px;
    }
    .btn-danger {
      background: #FF7B7B;
      color: #fff;
    }
    .btn-danger:hover { background: #e06666; }
    .btn-outline {
      background: transparent;
      border: 1px solid #ddd;
      color: #666;
    }
    .btn-outline:hover { border-color: #FF9A6B; color: #FF9A6B; }

    /* 搜索框 */
    .search-box {
      display: flex;
      gap: 8px;
      margin-bottom: 16px;
    }
    .search-box input {
      flex: 1;
      padding: 8px 16px;
      border: 1px solid #e0d8d0;
      border-radius: 8px;
      font-size: 14px;
      outline: none;
      max-width: 320px;
    }
    .search-box input:focus { border-color: #FF9A6B; }

    /* 错误/提示 */
    .alert {
      padding: 12px 16px;
      border-radius: 8px;
      margin-bottom: 16px;
      font-size: 14px;
    }
    .alert-error {
      background: #FFF0F0;
      color: #e06666;
      border: 1px solid #ffd4d4;
    }

    /* 详情页 */
    .detail-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 8px;
    }
    .detail-item {
      padding: 10px 0;
      border-bottom: 1px solid #f5f0eb;
    }
    .detail-label {
      font-size: 12px;
      color: #999;
      margin-bottom: 2px;
    }
    .detail-value {
      font-size: 14px;
      color: #4A3728;
    }

    /* 照片网格 */
    .photo-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
      gap: 8px;
    }
    .photo-grid img {
      width: 100%;
      height: 100px;
      object-fit: cover;
      border-radius: 8px;
      cursor: pointer;
    }

    /* 音频列表 */
    .sound-item {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 8px 0;
      border-bottom: 1px solid #f5f0eb;
    }
    .sound-play-btn {
      width: 36px;
      height: 36px;
      border-radius: 50%;
      background: #FF9A6B;
      color: #fff;
      border: none;
      cursor: pointer;
      font-size: 14px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .sound-info {
      flex: 1;
    }
    .sound-desc {
      font-size: 14px;
      color: #4A3728;
    }
    .sound-duration {
      font-size: 12px;
      color: #999;
    }

    /* 空状态 */
    .empty-state {
      text-align: center;
      padding: 60px 20px;
      color: #ccc;
    }
    .empty-state p { margin-top: 8px; }

    /* 配置展示 */
    .config-list {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 12px;
    }
    .config-item {
      background: #faf5f0;
      padding: 12px;
      border-radius: 8px;
    }
    .config-key {
      font-size: 11px;
      color: #999;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    .config-value {
      font-size: 14px;
      color: #4A3728;
      margin-top: 2px;
      word-break: break-all;
    }

    /* 表单样式 */
    .form-group {
      margin-bottom: 16px;
    }
    .form-label {
      display: block;
      font-size: 14px;
      font-weight: 500;
      color: #4A3728;
      margin-bottom: 6px;
    }
    .form-label .required {
      color: #FF7B7B;
    }
    .form-input, .form-textarea, .form-select {
      width: 100%;
      padding: 8px 12px;
      border: 1px solid #e0d8d0;
      border-radius: 8px;
      font-size: 14px;
      outline: none;
      transition: border-color 0.2s;
      box-sizing: border-box;
      font-family: inherit;
    }
    .form-input:focus, .form-textarea:focus, .form-select:focus {
      border-color: #FF9A6B;
    }
    .form-textarea {
      min-height: 80px;
      resize: vertical;
    }
    .form-hint {
      font-size: 12px;
      color: #999;
      margin-top: 4px;
    }
    .checkbox-group, .radio-group {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }
    .checkbox-label, .radio-label {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      padding: 6px 12px;
      background: #FFF8F0;
      border: 1px solid #f0e8e0;
      border-radius: 8px;
      font-size: 13px;
      cursor: pointer;
      transition: all 0.2s;
      user-select: none;
    }
    .checkbox-label:hover, .radio-label:hover {
      border-color: #FF9A6B;
      background: #FFF0E6;
    }
    .checkbox-label input, .radio-label input {
      accent-color: #FF9A6B;
    }
    .existing-files {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 12px;
    }
    .existing-photo {
      position: relative;
      width: 80px;
      height: 80px;
      border-radius: 8px;
      overflow: hidden;
      border: 1px solid #f0e8e0;
    }
    .existing-photo img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .existing-photo .del-btn {
      position: absolute;
      top: 2px;
      right: 2px;
      width: 20px;
      height: 20px;
      background: rgba(255,0,0,0.7);
      color: #fff;
      border: none;
      border-radius: 50%;
      font-size: 11px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      line-height: 1;
    }
    .existing-sound {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 8px 12px;
      background: #FFF8F0;
      border: 1px solid #f0e8e0;
      border-radius: 8px;
      font-size: 13px;
      margin-bottom: 6px;
    }
    .existing-sound .del-btn {
      background: #FF7B7B;
      color: #fff;
      border: none;
      border-radius: 4px;
      padding: 2px 8px;
      cursor: pointer;
      font-size: 12px;
      margin-left: auto;
    }
    .form-row {
      display: flex;
      gap: 12px;
    }
    .form-row .form-group {
      flex: 1;
    }
    .inline-flex {
      display: flex;
      align-items: center;
      gap: 8px;
    }

    /* 图片预览模态框 */
    .modal-overlay {
      display: none;
      position: fixed;
      top: 0; left: 0; right: 0; bottom: 0;
      background: rgba(0,0,0,0.8);
      z-index: 999;
      justify-content: center;
      align-items: center;
      cursor: pointer;
    }
    .modal-overlay.show { display: flex; }
    .modal-overlay img {
      max-width: 90%;
      max-height: 90%;
      border-radius: 8px;
    }
  </style>
</head>
<body>
  <% if (typeof manageUser !== 'undefined' && manageUser) { %>
  <nav class="navbar">
    <a class="navbar-brand" href="/<%= managePath %>">🐱 流浪猫足迹</a>
    <div class="navbar-nav">
      <span class="navbar-user"><%= manageUser.username %></span>
      <a href="/<%= managePath %>" class="<%= currentPath === '/' ? 'active' : '' %>">仪表盘</a>
      <a href="/<%= managePath %>/cats" class="<%= currentPath?.startsWith('/cats') ? 'active' : '' %>">猫咪列表</a>
      <a href="/<%= managePath %>/logout">退出</a>
    </div>
  </nav>
  <% } %>

  <div class="container">
    <%- body %>
  </div>

  <!-- 图片预览 -->
  <div class="modal-overlay" id="imageModal" onclick="this.classList.remove('show')">
    <img id="modalImage" src="" alt="预览">
  </div>

  <script>
    // 图片预览
    document.querySelectorAll('.preview-img').forEach(img => {
      img.addEventListener('click', function() {
        document.getElementById('modalImage').src = this.src
        document.getElementById('imageModal').classList.add('show')
      })
    })

    // 确认删除
    document.querySelectorAll('.btn-delete-confirm').forEach(btn => {
      btn.addEventListener('click', function(e) {
        if (!confirm('确定要删除该猫咪档案吗？此操作不可撤销！')) {
          e.preventDefault()
          return
        }
        const url = this.dataset.url
        fetch(url, { method: 'POST' })
          .then(r => r.json())
          .then(data => {
            if (data.success) {
              window.location.reload()
            } else {
              alert('删除失败: ' + (data.error || '未知错误'))
            }
          })
          .catch(err => alert('网络错误: ' + err.message))
      })
    })
  </script>
</body>
</html>
