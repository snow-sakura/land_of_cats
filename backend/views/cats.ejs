<div class="page-header" style="display:flex;justify-content:space-between;align-items:flex-start;">
  <div>
    <div class="page-title">猫咪列表</div>
    <div class="page-subtitle">共 <%= cats.length %> 只猫咪</div>
  </div>
  <a href="/<%= managePath %>/cats/new" class="btn btn-primary">+ 新增猫咪</a>
</div>

<% if (typeof error !== 'undefined' && error) { %>
<div class="alert alert-error"><%= error %></div>
<% } %>

<!-- 搜索 -->
<form method="GET" action="/<%= managePath %>/cats">
  <div class="search-box">
    <input type="text" name="search" placeholder="搜索猫咪昵称..." value="<%= search %>">
    <button type="submit" class="btn btn-primary btn-sm">搜索</button>
    <% if (search) { %>
    <a href="/<%= managePath %>/cats" class="btn btn-outline btn-sm">清除</a>
    <% } %>
  </div>
</form>

<!-- 列表 -->
<% if (cats.length === 0) { %>
<div class="card">
  <div class="empty-state">
    <p><%= search ? '没有找到匹配的猫咪' : '暂无猫咪数据' %></p>
  </div>
</div>
<% } else { %>
<div class="card">
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>ID</th>
          <th>照片</th>
          <th>昵称</th>
          <th>毛色</th>
          <th>地点</th>
          <th>用户</th>
          <th>创建时间</th>
          <th>操作</th>
        </tr>
      </thead>
      <tbody>
        <% cats.forEach(c => { %>
        <tr>
          <td><%= c.id %></td>
          <td>
            <% if (c.coverUrl) { %>
            <img src="<%= c.coverUrl %>" class="preview-img" style="width:40px;height:40px;border-radius:6px;object-fit:cover;cursor:pointer;" alt="">
            <% } else { %>
            <span style="color:#ccc;">无</span>
            <% } %>
          </td>
          <td><strong><%= c.nickname %></strong></td>
          <td>
            <% (c.coatColors || []).forEach(color => { %>
            <span class="tag"><%= color %></span>
            <% }) %>
          </td>
          <td style="max-width:150px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= c.locationName %></td>
          <td style="max-width:100px;overflow:hidden;text-overflow:ellipsis;" title="<%= c.openid %>">
            <% if (c.userDisplay) { %><%= c.userDisplay %><% } else { %><span style="color:#ccc;">—</span><% } %>
          </td>
          <td style="font-size:12px;color:#999;white-space:nowrap;"><%= new Date(c.createTime).toLocaleString('zh-CN') %></td>
          <td style="white-space:nowrap;">
            <a href="/<%= managePath %>/cats/<%= c.id %>" class="btn btn-primary btn-sm" style="text-decoration:none;">详情</a>
            <button class="btn btn-danger btn-sm btn-delete-confirm" data-url="/<%= managePath %>/cats/<%= c.id %>/delete" style="margin-left:4px;">删除</button>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
<% } %>
